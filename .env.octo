# Subrunner (Octomate) — merge these entries into your local .env (do not commit real secrets).
# Copy the variables you need into .env and set real values.

# Flask secret key - replace with a long random string
SECRET_KEY=YOUR_SECRET_KEY_HERE
# Absolute path to the SQLite database file inside the Flask instance folder
DATABASE_PATH=/path/to/your/instance/database.db
# Comma-separated list of hostnames that fetchUserData() in vuln.js is allowed to contact
ALLOWED_FETCH_HOSTS=api.example.com,data.example.com
