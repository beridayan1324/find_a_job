# Subrunner (Octomate) — merge these entries into your local .env (do not commit real secrets).
# Copy the variables you need into .env and set real values.

SECRET_KEY=YOUR_SECRET_KEY_HERE
DATABASE_URL= # optional: defaults to sqlite in instance folder, e.g. sqlite:////path/to/database.db
ALLOWED_FETCH_HOSTS= # comma-separated hostnames allowed for fetchUserData, e.g. api.example.com,data.example.com
